localhost {
    # Proxy API requests to backend
    handle_path /api* {
        reverse_proxy backend:8000
    }

    # Proxy WebSocket requests to backend
    handle /ws* {
        reverse_proxy backend:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Proxy all other requests to frontend
    handle {
        root * /srv
        file_server
        try_files {path} /index.html
    }
}

